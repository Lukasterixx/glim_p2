{
  /*** GlobalMapping ***
  // See config_global_mapping_gpu.json for the full description of the parameters.
  */
  "global_mapping": {
    "so_name": "libglobal_mapping.so",
    "enable_imu": true,
    "enable_optimization": true,
    "init_pose_damping_scale": 1e10,
    // Relative pose factors
    "create_between_factors": true,
    "between_registration_type": "GICP",
    // Registration error factors
    "registration_error_factor_type": "VGICP",
    "randomsampling_rate": 0.2,
    "submap_voxel_resolution": 0.5,
    "submap_voxelmap_levels": 1,
    "submap_voxelmap_scaling_factor": 2.0,
    "max_implicit_loop_distance": 100.0,
    "min_implicit_loop_overlap": 0.2,
    // Optimizer settings
    "use_isam2_dogleg": false,
    "isam2_relinearize_skip": 1,
    "isam2_relinearize_thresh": 0.1,
    // Session continuation ("as if GLIM was never turned off"). See config_global_mapping_gpu.json
    // for full docs. Empty continue_from_map_path = normal (fresh) mapping.
    "continue_from_map_path": "",
    "save_map_path": "",
    "freeze_loaded_map": true,
    "freeze_prior_precision": 1e10,
    "reloc_method": "yaw_sweep",
    "reloc_yaw_step_deg": 15.0,
    "reloc_voxel_resolution": 0.5,
    "reloc_fpfh_radius": 2.5,
    "reloc_dof": 4,
    "reloc_search_radius_m": 3.0,
    "reloc_start_area_radius_m": 20.0,
    "reloc_min_inlier_rate": 0.3,
    // 0 == unbounded retries: keep buffering + retrying instead of giving up and falling back
    // to fresh mapping, so an operator can still accept/adjust a pose on ~/reloc_override.
    "reloc_max_submaps": 0,
    "reloc_refine": true,
    "reloc_refine_max_correction": 1.0,
    "reloc_refine_min_inlier_rate": 0.6,
    "reloc_registration": "RANSAC",
    "num_threads": 4
  }
}