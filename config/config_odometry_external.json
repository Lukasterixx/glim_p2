{
  /*** OdometryEstimationExternal ("sim-mode") ***
  // Trusts an external "odom -> lidar" transform (looked up via TF) as the sensor pose
  // for every scan, instead of estimating odometry. No IMU is used. Pair this with
  // libsub_mapping_passthrough.so so the mapping backend keeps the external poses verbatim.
  //
  // so_name        : Shared library implementing the odometry frontend
  // num_threads    : Threads used for point covariance estimation
  // lookup_timeout : Max time [sec] to wait for the external transform of a scan to arrive
  //
  // The parent/child frames of the external transform are read from config_ros.json:
  //   odom_frame_id  (parent, used as the mapping world frame)
  //   lidar_frame_id (child, must match the point cloud frame)
  //
  // To continue from / align onto a previously-saved map, use GlobalMapping session
  // continuation (global_mapping/continue_from_map_path in config_global_mapping*.json).
  */
  "odometry_estimation": {
    "so_name": "libodometry_estimation_external.so",
    "num_threads": 4,
    "lookup_timeout": 0.1
  }
}
